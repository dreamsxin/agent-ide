{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent IDE",
  "version": "0.1.0",
  "identifier": "com.agentide.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../client run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "npm --prefix ../client run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent IDE",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
